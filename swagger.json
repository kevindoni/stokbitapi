                                                },
                                                "created_at": {
                                                    "type": "string",
                                                    "format": "date-time"
                                                },
                                                "statistics": {
                                                    "type": "object"
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/proxy/notification/count/unread": {
            "get": {
                "tags": [
                    "User"
                ],
                "summary": "Unread Notifications",
                "description": "Count of unread notifications for the authenticated user.",
