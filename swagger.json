                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/proxy/portfolio/v2/summary": {
            "get": {
                "tags": [
                    "Trading"
                ],
                "summary": "Portfolio Summary",
                "description": "Get trading portfolio summary: balance, invested amount, equity, P&L, credit limit. Requires Securities Token.",
                "responses": {
                    "200": {
                        "description": "Portfolio summary with balance and equity",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "OK"
                                        },
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "aggregated_portfolio_summary": {
                                                    "type": "object",
                                                    "properties": {
                                                        "trading": {
                                                            "type": "object",
                                                            "properties": {
                                                                "balance": {
                                                                    "type": "number",
                                                                    "example": 6970.51
                                                                }
                                                            }
                                                        },
                                                        "amount": {
                                                            "type": "object",
                                                            "properties": {
                                                                "invested": {
                                                                    "type": "number"
                                                                },
                                                                "credit_limit": {
                                                                    "type": "number"
                                                                }
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Securities token expired or missing"
                    }
                }
            }
        },
        "/proxy/order/v2/list": {
            "get": {
                "tags": [
                    "Trading"
                ],
                "summary": "Order List",
                "description": "Get list of active trading orders. Requires Securities Token.",
                "responses": {
                    "200": {
                        "description": "Active order list"
                    },
                    "401": {
                        "description": "Securities token expired or missing"
                    }
                }
            }
        },
        "/analysis/technicals/{symbol}": {
            "get": {
                "tags": [
                    "Analysis (Custom)"
